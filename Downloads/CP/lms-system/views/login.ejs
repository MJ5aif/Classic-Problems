<%- include('partials/header') %>

<!-- Login Page -->
<div class="auth-container">
  <div class="auth-card">
    <h2>Welcome Back</h2>
    <p class="subtitle">Login to your LMS account</p>

    <div id="loginAlert"></div>

    <!-- Who is logging in? -->
    <div class="form-group">
      <label for="loginRole">Logging in as</label>
      <select id="loginRole" class="form-control" onchange="onRoleChange(this.value)"
              style="cursor:pointer; font-weight:600;">
        <option value="learner">👨‍🎓 Student / Learner</option>
        <option value="instructor">👨‍🏫 Instructor</option>
        <option value="admin">🔑 Admin</option>
      </select>
    </div>

    <form id="loginForm" onsubmit="handleLogin(event)">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" class="form-control" placeholder="Enter your email" required>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" class="form-control" placeholder="Enter your password" required>
      </div>

      <button type="submit" class="btn btn-primary btn-block btn-lg" id="loginBtn">
        Login
      </button>
    </form>

    <p class="text-center mt-2 text-gray">
      Don't have an account? <a href="/auth/register">Register here</a>
    </p>

    <!-- Demo credentials card — changes with dropdown -->
    <div class="mt-3" style="background: var(--light-gray); padding: 1rem; border-radius: 8px;">
      <p class="text-sm font-bold mb-1">Demo Credentials:</p>
      <div id="demoCreds">
        <!-- filled by JS -->
      </div>
    </div>
  </div>
</div>

<script>
  // Redirect if already logged in
  (function() {
    const cookies = document.cookie.split(';');
    for (let cookie of cookies) {
      const [name] = cookie.trim().split('=');
      if (name === 'token') { window.location.href = '/dashboard'; return; }
    }
  })();

  const DEMO = {
    learner: [
      '<span class="text-sm text-gray">Register a new account to try as learner</span>'
    ],
    instructor: [
      '<span class="text-sm text-gray">📧 fakhrul.hossain@lms.com &nbsp;/&nbsp; ins@123</span>',
      '<span class="text-sm text-gray">📧 ishtiaque.zahid@lms.com &nbsp;/&nbsp; ins@1234</span>',
      '<span class="text-sm text-gray">📧 mainul.hasan@lms.com &nbsp;/&nbsp; ins@12345</span>'
    ],
    admin: [
      '<span class="text-sm text-gray">📧 admin@lms.com &nbsp;/&nbsp; admin123</span>'
    ]
  };

  function onRoleChange(role) {
    const box = document.getElementById('demoCreds');
    box.innerHTML = DEMO[role].map(l => `<p style="margin:0.2rem 0">${l}</p>`).join('');
  }
  // Init with learner
  onRoleChange('learner');

  async function handleLogin(e) {
    e.preventDefault();
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const btn = document.getElementById('loginBtn');
    const alertDiv = document.getElementById('loginAlert');

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Logging in...';

    try {
      const result = await apiCall('/auth/login', 'POST', { email, password });
      if (result.success) {
        document.cookie = `token=${result.data.token}; path=/; max-age=${7 * 24 * 60 * 60}`;
        alertDiv.innerHTML = '<div class="alert alert-success">Login successful! Redirecting...</div>';
        setTimeout(() => { window.location.href = '/dashboard'; }, 500);
      } else {
        alertDiv.innerHTML = `<div class="alert alert-danger">${result.message}</div>`;
        btn.disabled = false; btn.textContent = 'Login';
      }
    } catch (error) {
      alertDiv.innerHTML = '<div class="alert alert-danger">Network error. Please try again.</div>';
      btn.disabled = false; btn.textContent = 'Login';
    }
  }
</script>

<%- include('partials/footer') %>
