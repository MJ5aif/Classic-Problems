<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'LMS System' %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <script>
    window.__isLoggedIn = <%= (typeof currentUser !== 'undefined' && currentUser) || (typeof user !== 'undefined' && user) ? 'true' : 'false' %>;
    window.__userRole = '<%= typeof currentUser !== 'undefined' && currentUser ? currentUser.role : (typeof user !== 'undefined' && user ? user.role : '') %>';
  </script>
  <nav class="navbar">
    <a href="/" class="navbar-brand">
      <img src="/images/logo.svg" alt="EduLearn Pro" style="height:76px;width:auto;vertical-align:middle;border-radius:18px;">
    </a>
    <div class="navbar-links" id="navLinks">
      <a href="/">Home</a>
      <a href="/courses-page">Courses</a>
      <% var navUser = (typeof currentUser !== 'undefined' && currentUser) ? currentUser : (typeof user !== 'undefined' ? user : null); %>
      <% if (navUser) { %>
        <a href="/dashboard">Dashboard</a>
        <a href="/profile">My Profile</a>
        <span class="nav-user">
          <% if (navUser.profilePicture) { %>
            <img src="<%= navUser.profilePicture %>" alt="<%= navUser.name %>" style="width:28px;height:28px;border-radius:50%;object-fit:cover;vertical-align:middle;margin-right:5px;border:2px solid rgba(255,255,255,0.7);">
          <% } else { %>👤 <% } %><%= navUser.name %> (<%= navUser.role %>)
        </span>
        <a href="#" onclick="logout()" class="btn btn-sm btn-outline">Logout</a>
      <% } else { %>
        <a href="/auth/login" class="btn btn-sm btn-primary">Login</a>
        <a href="/auth/register" class="btn btn-sm btn-outline">Register</a>
      <% } %>
    </div>
  </nav>
