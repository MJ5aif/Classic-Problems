<%- include('partials/header') %>

<!-- Learner Dashboard -->
<div class="container">
  <div class="dashboard-header">
    <div>
      <h1>👋 Welcome, <%= user.name %></h1>
      <p class="text-gray">Your learning dashboard</p>
    </div>
    <a href="/courses-page" class="btn btn-primary">Browse Courses</a>
  </div>

  <div id="dashAlert"></div>

  <!-- Bank Account Setup -->
  <% if (!hasBankAccount) { %>
    <div class="alert alert-warning mb-3">
      ⚠️ <strong>Action Required:</strong> Please set up your bank account to purchase courses.
    </div>
    <div class="card mb-3">
      <div class="card-header">
        <h3>🏦 Set Up Bank Account</h3>
      </div>
      <div class="card-body">
        <form id="bankForm" onsubmit="setupBank(event)">
          <div class="grid grid-2">
            <div class="form-group">
              <label for="accountNumber">Account Number (10 digits)</label>
              <input type="text" id="accountNumber" class="form-control" placeholder="e.g. 1234567890" 
                     pattern="\d{10}" maxlength="10" required>
            </div>
            <div class="form-group">
              <label for="secretKey">Secret Key (min 4 characters)</label>
              <input type="password" id="secretKey" class="form-control" placeholder="Your secret key" 
                     minlength="4" required>
            </div>
          </div>
          <button type="submit" class="btn btn-success" id="bankBtn">Create Bank Account</button>
        </form>
      </div>
    </div>
  <% } else { %>
    <!-- Balance Card -->
    <div class="grid grid-3 mb-3">
      <div class="balance-card">
        <div class="balance-label">Bank Balance</div>
        <div class="balance-amount">৳<%= bankBalance.toLocaleString() %></div>
        <div class="balance-account">Account: <%= user.bankAccountNumber %></div>
        <a href="/transaction-history" style="display:inline-block;margin-top:.75rem;font-size:.82rem;background:rgba(255,255,255,.18);color:#fff;padding:.3rem .9rem;border-radius:6px;text-decoration:none;">🧾 Transaction History</a>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= user.purchasedCourses ? user.purchasedCourses.length : 0 %></div>
        <div class="stat-label">Courses Enrolled</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= user.purchasedCourses ? user.purchasedCourses.filter(c => c.completed).length : 0 %></div>
        <div class="stat-label">Completed</div>
      </div>
    </div>
  <% } %>

  <!-- My Courses -->
  <div class="dashboard-section">
    <h2>📚 My Courses</h2>
    
    <% if (user.purchasedCourses && user.purchasedCourses.length > 0) { %>
      <div class="grid grid-2">
        <% user.purchasedCourses.forEach(function(pc) { %>
          <% if (pc.courseId) { %>
            <div class="card">
              <div class="card-body">
                <div class="flex-between">
                  <div>
                    <h3><%= pc.courseId.title %></h3>
                    <p class="text-sm text-gray mt-1">
                      by <% if (pc.courseId.instructorId) { %><a href="/profile/<%= pc.courseId.instructorId._id %>" style="color:var(--primary);"><%= pc.courseId.instructorId.name %></a><% } else { %>Unknown<% } %>
                    </p>
                    <p class="text-sm text-gray mt-1">
                      <%= pc.courseId.materials ? pc.courseId.materials.length : 0 %> lessons
                    </p>
                  </div>
                  <div class="text-right">
                    <%
                      const certData = typeof myCertificates !== 'undefined' && myCertificates
                        ? myCertificates[pc.courseId._id.toString()]
                        : null;
                    %>
                    <% if (certData && certData.status === 'accepted') { %>
                      <span class="badge badge-success">🏆 Certified</span>
                      <br>
                      <a href="/certificate-page/<%= pc.courseId._id %>" class="btn btn-sm btn-primary mt-1">
                        📜 Download Certificate
                      </a>
                    <% } else if (certData && certData.status === 'pending') { %>
                      <span class="badge badge-warning">⏳ Awaiting Approval</span>
                      <br>
                      <span class="text-sm text-gray" style="display:block;margin-top:0.3rem;font-size:0.75rem;">Applied — instructor reviewing</span>
                    <% } else if (certData && certData.status === 'rejected') { %>
                      <span class="badge badge-danger">❌ Rejected</span>
                      <% if (certData.rejectionReason) { %>
                        <span class="text-sm text-gray" style="display:block;margin-top:0.3rem;font-size:0.75rem;color:var(--danger);">
                          "<%= certData.rejectionReason %>"
                        </span>
                      <% } %>
                    <% } else { %>
                      <span class="badge badge-warning">📖 In Progress</span>
                      <br>
                      <button class="btn btn-sm btn-success mt-1"
                              onclick="applyCertificate('<%= pc.courseId._id %>', '<%= (pc.courseId.title||'').replace(/'/g,'&#39;') %>')">
                        🎓 Apply for Certificate
                      </button>
                    <% } %>
                  </div>
                </div>

                <!-- Action Buttons -->
                <div class="mt-2" style="border-top: 1px solid var(--border); padding-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                  <a href="/course/<%= pc.courseId._id %>" class="btn btn-sm btn-primary">📖 View Course Content</a>
                  <% if (pc.courseId.materials && pc.courseId.materials.length > 0) { %>
                    <span class="text-sm text-gray" style="display: flex; align-items: center;">
                      📚 <%= pc.courseId.materials.length %> lessons available
                      <% const videoCount = pc.courseId.materials.filter(m => m.type === 'video').length; %>
                      <% if (videoCount > 0) { %>
                        &nbsp;• 🎬 <%= videoCount %> video<%= videoCount > 1 ? 's' : '' %>
                      <% } %>
                    </span>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="icon">📖</div>
        <h3>No Courses Yet</h3>
        <p>Browse our courses and start learning today!</p>
        <a href="/courses-page" class="btn btn-primary mt-2">Browse Courses</a>
      </div>
    <% } %>
  </div>
</div>

<script>
  // Set up bank account
  async function setupBank(e) {
    e.preventDefault();
    const accountNumber = document.getElementById('accountNumber').value;
    const secretKey = document.getElementById('secretKey').value;
    const btn = document.getElementById('bankBtn');
    const alertDiv = document.getElementById('dashAlert');

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Setting up...';

    try {
      const result = await apiCall('/bank/create-account', 'POST', { accountNumber, secretKey });

      if (result.success) {
        alertDiv.innerHTML = '<div class="alert alert-success">🎉 Bank account created with ৳10,000 balance!</div>';
        setTimeout(() => window.location.reload(), 1500);
      } else {
        alertDiv.innerHTML = `<div class="alert alert-danger">${result.message}</div>`;
        btn.disabled = false;
        btn.textContent = 'Create Bank Account';
      }
    } catch (error) {
      alertDiv.innerHTML = '<div class="alert alert-danger">Error setting up bank account.</div>';
      btn.disabled = false;
      btn.textContent = 'Create Bank Account';
    }
  }

  // Apply for certificate
  async function applyCertificate(courseId, courseTitle) {
    if (!confirm(`Apply for a certificate for "${courseTitle}"?\nYour instructor will review and approve your application.`)) return;

    const alertDiv = document.getElementById('dashAlert');

    try {
      const result = await apiCall(`/courses/certificate/apply/${courseId}`, 'POST');

      if (result.success) {
        alertDiv.innerHTML = `<div class="alert alert-success">🎉 ${result.message}</div>`;
        setTimeout(() => window.location.reload(), 1500);
      } else {
        alertDiv.innerHTML = `<div class="alert alert-danger">${result.message}</div>`;
      }
    } catch (error) {
      alertDiv.innerHTML = '<div class="alert alert-danger">Error submitting application.</div>';
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>

<%- include('partials/footer') %>
